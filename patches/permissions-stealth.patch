@@ -267,6 +267,14 @@ blink::mojom::PermissionStatus PermissionManager::GetPermissionStatusForFrame(
     const GURL& requesting_origin,
     const GURL& embedding_origin) {
   ContentSetting content_setting = GetPermissionStatus(permission, requesting_origin, embedding_origin);
